{
  "name": "@uicraft/core",
  "version": "1.4.2",
  "description": "UI component library — pure CSS utility classes, design tokens, dark mode, vanilla JS bundle.",
  "license": "MIT",
  "author": "Taras Tarasenko <by.tarasenko@gmail.com>",
  "homepage": "https://getuicraft.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarasenko-by/uicraft-core.git"
  },
  "bugs": {
    "url": "https://github.com/tarasenko-by/uicraft-core/issues"
  },
  "keywords": [
    "ui",
    "css",
    "design-system",
    "components",
    "design-tokens",
    "dark-mode",
    "figma"
  ],
  "main": "uicraft.min.js",
  "style": "uicraft.min.css",
  "exports": {
    ".": {
      "import": "./uicraft.min.js",
      "default": "./uicraft.min.js"
    },
    "./css": "./uicraft.min.css",
    "./css/unminified": "./uicraft.css",
    "./js/unminified": "./uicraft.js",
    "./theme-manifest": "./theme-manifest.json",
    "./themes/*": "./themes/*"
  },
  "files": [
    "uicraft.css",
    "uicraft.min.css",
    "uicraft.js",
    "uicraft.min.js",
    "theme-manifest.json",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ]
}
